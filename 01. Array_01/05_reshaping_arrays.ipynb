   "source": [
    "# operations on arrays\n",
    "arr = np.array([[1,2,3],[3,4,5]])\n",
    "print(arr, arr.shape)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "a516d927-4997-48fa-9ac5-31a5f1fc5207",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[[1 2]\n",
      " [3 3]\n",
      " [4 5]] (3, 2)\n"
     ]
    }
   ],
   "source": [
    "reshaped = arr.reshape((3,2))\n",
    "print(reshaped, reshaped.shape)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "6357db47-7108-4e65-bafb-d40e7d47e7f8",
